# Vendor Web App Map Configurations

# To configure mapping providers in the Web app, copy this file to '.env'
# and define the keys you want to use.

# Option A: Mapbox Tiles (Recommended for dark theme matching)
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# Option B: Google Maps Tiles
VITE_GOOGLE_MAPS_API_KEY=AIzaSyYourKeyHere

# Note: If no variables are set in the .env, the web app will fall back
# to the free CartoDB Dark Matter tile layer automatically.
