PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=deliveryapp
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Required for secure initial-password delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-provider-app-password
SMTP_FROM=LPG Delivery <mailer@example.com>

ADMIN_COMMISSION_RATE=2
DELIVERY_BASE_FEE=2
DELIVERY_PER_KM_FEE=0.5
ASSIGNMENT_RESPONSE_MINUTES=5
VENDOR_RESPONSE_MINUTES=5

# Hurmood/WAAFI API_PURCHASE merchant credentials.
# Customer phone is sent as payerInfo.accountNo; money goes to this merchant/vendor.
HURMOOD_API_URL=https://api.waafipay.net/asm
HURMOOD_MERCHANT_UID=replace-with-merchant-uid
HURMOOD_API_USER_ID=replace-with-api-user-id
HURMOOD_API_KEY=replace-with-rotated-api-key
HURMOOD_VENDOR_ID=replace-with-the-vendor-id-that-owns-this-merchant
HURMOOD_TIMEOUT_MS=30000
