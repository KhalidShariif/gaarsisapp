PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=deliveryapp
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Required for secure initial-password delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-provider-app-password
SMTP_FROM=LPG Delivery <mailer@example.com>

ADMIN_COMMISSION_RATE=2
DELIVERY_BASE_FEE=2
DELIVERY_PER_KM_FEE=0.5
ASSIGNMENT_RESPONSE_MINUTES=5
VENDOR_RESPONSE_MINUTES=5

# WAAFI Pay API_PURCHASE. Use a separate merchant per vendor via the JSON map when required.
WAAFI_API_URL=https://api.waafipay.net/asm
WAAFI_MERCHANT_UID=replace-with-merchant-uid
WAAFI_API_USER_ID=replace-with-api-user-id
WAAFI_API_KEY=replace-with-rotated-api-key
WAAFI_DEFAULT_VENDOR_ID=replace-with-the-vendor-id-that-owns-this-merchant
WAAFI_TIMEOUT_MS=30000
# WAAFI_VENDOR_ACCOUNTS_JSON={"12":{"merchantUid":"M...","apiUserId":"...","apiKey":"..."}}
